local Rarity = {
    "Mythic",
    "Legendary",
    "Epic",
    "Rare",
    "Uncommon",
    "Common"
}

local RarityRank = {}
for i, v in ipairs(Rarity) do
    RarityRank[v] = i
end

local TARGET_SET = "Celestial Rupture"
local TARGET_RARITY = "Legendary"

function EquipBestArtifact()
    local RS = game:GetService("ReplicatedStorage")
    local GetArtifactData = RS:WaitForChild("RemoteFunctions"):WaitForChild("GetArtifactData")
    local ArtifactEquip = RS:WaitForChild("RemoteEvents"):WaitForChild("ArtifactEquip")
    local ArtifactDelete = RS:WaitForChild("RemoteEvents"):WaitForChild("ArtifactDelete")
    local ArtifactUpgrade = RS:WaitForChild("RemoteEvents"):WaitForChild("ArtifactUpgrade")

    local MAX_LEVEL = 15
    local DELAY = 0.3

    local ArtifactData = GetArtifactData:InvokeServer()
    local Inventory = ArtifactData["Inventory"]
    local Equipped = ArtifactData["Equipped"]

    local bestByCategory = {
        Helmet = { uuid = nil, value = -1, rarity = math.huge, isPerfect = false },
        Body = { uuid = nil, value = -1, rarity = math.huge, isPerfect = false },
        Gloves = { uuid = nil, value = -1, rarity = math.huge, isPerfect = false },
        Boots = { uuid = nil, value = -1, rarity = math.huge, isPerfect = false },
    }

    for uuid, artifact in pairs(Inventory) do
        local category = artifact["Category"]
        if bestByCategory[category] then
            local value = artifact["MainStat"]["Value"] or 0
            local rarityName = artifact["Rarity"]
            local rarity = RarityRank[rarityName] or math.huge

            local isPerfect = (artifact["Set"] == TARGET_SET and rarityName == TARGET_RARITY)

            local best = bestByCategory[category]

            -- 🔥 PRIORITY สูงสุด: Set + Legendary
            if isPerfect then
                if not best.isPerfect or value > best.value then
                    best.uuid = uuid
                    best.value = value
                    best.rarity = rarity
                    best.isPerfect = true
                end
            else
                -- fallback (เฉพาะกรณีที่ยังไม่มีของ perfect)
                if not best.isPerfect then
                    if rarity < best.rarity or (rarity == best.rarity and value > best.value) then
                        best.uuid = uuid
                        best.value = value
                        best.rarity = rarity
                    end
                end
            end
        end
    end

    local bestUUIDs = {}
    for _, data in pairs(bestByCategory) do
        if data.uuid then
            bestUUIDs[data.uuid] = true
        end
    end

    -- equip
    for category, data in pairs(bestByCategory) do
        if data.uuid then
            if not (Equipped and Equipped[category] == data.uuid) then
                ArtifactEquip:FireServer(data.uuid)
                task.wait(DELAY)
            end
        end
    end

    -- delete (ไม่ลบของ Perfect)
    for uuid, artifact in pairs(Inventory) do
        local category = artifact["Category"]
        local isPerfect = (artifact["Set"] == TARGET_SET and artifact["Rarity"] == TARGET_RARITY)

        if bestByCategory[category]
        and not bestUUIDs[uuid]
        and artifact["Rarity"] ~= "Legendary"
        and not isPerfect then

            ArtifactDelete:FireServer(uuid)
            task.wait(DELAY)
        end
    end

    -- upgrade
    for _, data in pairs(bestByCategory) do
        if data.uuid then
            local artifact = Inventory[data.uuid]
            local currentLevel = artifact["Level"] or 0

            if currentLevel < MAX_LEVEL then
                ArtifactUpgrade:FireServer(data.uuid, 1)
                task.wait(DELAY)
            end
        end
    end
end

