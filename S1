function Player:GetQuest()
    Quest = require(game:GetService("ReplicatedStorage").Modules.QuestConfig)
    Stats = Player:GetStats()
    bestquest = nil
    Level = Stats.Level
    nm = nil
    dist = -math.huge
    for i,v in pairs(Quest.RepeatableQuests) do
        if v.requirements and v.requirements[1] and v.requirements[1].amount and v.requirements[1].amount > 1 and Level >= v.recommendedLevel then
 
            if dist < v.recommendedLevel then
                dist = v.recommendedLevel
                bestquest = v
                nm = tostring(i)
            end
        end
    end
    return bestquest , nm
end
 
