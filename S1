    Monny = game:GetService("Players").LocalPlayer.Data.Money.Value
    Gems = game:GetService("Players").LocalPlayer.Data.Gems.Value
 
 
    Player:GetHakiProgress()
 
    if Quest == "Path to Haki 1" or Quest == "Path to Haki 2" or Quest == "Path to Haki Final" then
 
        if not game:GetService("Players").LocalPlayer.Backpack:FindFirstChild("Combat")
        and not game:GetService("Players").LocalPlayer.Character:FindFirstChild("Combat")
        and (Player:IsSwordHave("Combat") or Player:IsMeleeHave("Combat")) then
 
            local args = {"Equip","Combat"}
            game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("EquipWeapon"):FireServer(unpack(args))
        end
 
        for i,v in pairs(workspace.NPCs:GetChildren()) do
            v.Name = v.Name:gsub("%d" , "")
            if v.Name == "Thief" and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
 
                repeat task.wait()
                    task.spawn(function()
                        Player:UpgradeStat()
                        Player:EquipTool("Combat")
                    end)
 
                    TeleportToEnemy(v)
 
                    if Quest == "Path to Haki 2" then
                        local args = {"AutoSkillZ",true}
                        game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("SettingsToggle"):FireServer(unpack(args))
                    else
                        game:GetService("ReplicatedStorage"):WaitForChild("CombatSystem"):WaitForChild("Remotes"):WaitForChild("RequestHit"):FireServer()
                    end
 
                until not v.Parent or not v:FindFirstChild("Humanoid") or v.Humanoid.Health <= 0
            elseif v.Name == "Thief" and not v:FindFirstChild("HumanoidRootPart") then
                TeleportToEnemy(v)
            end
        end
 
        return true
 
    elseif Level >= 50 and not game.Players.LocalPlayer.Character["Right Arm"]:FindFirstChild("3") and Level > 1000 then
        if Monny >= 250000 and Gems >= 250 then
 
        else
            return
        end
        TeleportToEnemy(workspace.ServiceNPCs.HakiQuestNPC)
        local args = {"HakiQuestNPC"}
        game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("QuestAccept"):FireServer(unpack(args))
        game:GetService("Players").LocalPlayer.PlayerGui.QuestUI.Quest.Quest.Holder.Content.QuestInfo.QuestTitle.QuestTitle.Text = ""
        if Quest == "Dungeon Discovery" or Quest == "Prove Your Strength" then
            local args = {
                "DungeonUnlock"
            }
            game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("QuestAbandon"):FireServer(unpack(args))
            game:GetService("Players").LocalPlayer.PlayerGui.QuestUI.Quest.Quest.Holder.Content.QuestInfo.QuestTitle.QuestTitle.Text = "None"
        else
            local args = {
                "repeatable"
            }
            game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("QuestAbandon"):FireServer(unpack(args))
        end
 
        task.wait(.2)
        local args = {"HakiQuestNPC"}
        game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("QuestAccept"):FireServer(unpack(args))
        repeat task.wait()
            if (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - workspace.ServiceNPCs.HakiQuestNPC.WorldPivot.Position).Magnitude > 50 then
                TeleportToEnemy(workspace.ServiceNPCs.HakiQuestNPC)
                local args = {"HakiQuestNPC"}
                game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("QuestAccept"):FireServer(unpack(args))
            else
                game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = workspace.ServiceNPCs.HakiQuestNPC.WorldPivot
            end
        until workspace.ServiceNPCs.HakiQuestNPC:FindFirstChild("HumanoidRootPart") and workspace.ServiceNPCs.HakiQuestNPC.HumanoidRootPart:FindFirstChild("HakiQuestPrompt")
        task.wait(.3)
        local args = {"HakiQuestNPC"}
        game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("QuestAccept"):FireServer(unpack(args))
        fireproximityprompt(workspace.ServiceNPCs.HakiQuestNPC.HumanoidRootPart.HakiQuestPrompt)
        return true
    end
 
